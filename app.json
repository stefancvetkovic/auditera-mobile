{
  "expo": {
    "name": "Auditera",
    "slug": "auditera-mobile",
    "version": "1.0.0",
    "scheme": "auditera",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Dozvolite pristup kameri za slikanje računa."
        }
      ],
      "expo-web-browser"
    ]
  }
}
