{
  "expo": {
    "name": "Auditera",
    "slug": "auditera-mobile",
    "version": "1.1.0",
    "scheme": "auditera",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ostrichtech.auditera",
      "buildNumber": "3"
    },
    "android": {
      "package": "com.ostrichtech.auditera",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Dozvolite pristup kameri za slikanje računa.",
          "enableMicrophonePermission": false,
          "enableLocation": false
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Koristite Face ID za brzu prijavu u aplikaciju."
        }
      ]
    ]
  }
}
